# URL dasar backend ASP.NET Core. Dipakai HANYA di sisi server Next.js
# (lewat rewrites di next.config.js) untuk mem-proxy permintaan /api/* dan /health.
# Browser tidak pernah memanggil URL ini langsung -> menghindari mixed content
# (halaman HTTPS di Vercel memanggil path relatif, server meneruskan ke HTTP EC2).
#
# Lokal: salin file ini menjadi .env.local lalu isi nilainya.
# Vercel: set sebagai Environment Variable bernama API_BASE_URL.
API_BASE_URL=http://18.143.171.142:8080
